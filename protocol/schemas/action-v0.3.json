{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "action-v0.3.json",
  "title": "Training Action v0.3",
  "type": "object",
  "additionalProperties": false,
  "required": ["leftHandTargetLocal", "rightHandTargetLocal", "durationMs"],
  "properties": {
    "leftHandTargetLocal": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "items": { "type": "number" },
      "description": "Player-root-local target for the left hand."
    },
    "rightHandTargetLocal": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "items": { "type": "number" },
      "description": "Player-root-local target for the right hand."
    },
    "durationMs": {
      "type": "integer",
      "minimum": 1,
      "maximum": 1000,
      "description": "Requested action window in milliseconds."
    }
  }
}

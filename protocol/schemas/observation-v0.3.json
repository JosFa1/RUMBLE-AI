{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "observation-v0.3.json",
  "title": "Training Observation v0.3",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "protocolVersion",
    "tick",
    "timeSeconds",
    "observationSpace",
    "actionTargetSpace",
    "sceneReady",
    "episodeId",
    "episodeStep",
    "rootPosition",
    "rootRotation",
    "headPosition",
    "headRotation",
    "leftHandPosition",
    "leftHandRotation",
    "rightHandPosition",
    "rightHandRotation",
    "health",
    "error",
    "warnings"
  ],
  "properties": {
    "protocolVersion": { "type": "string" },
    "tick": { "type": "integer" },
    "timeSeconds": { "type": "number" },
    "observationSpace": { "type": "string" },
    "actionTargetSpace": { "type": "string" },
    "sceneReady": { "type": "boolean" },
    "episodeId": { "type": "integer" },
    "episodeStep": { "type": "integer" },
    "rootPosition": { "$ref": "#/$defs/vector3" },
    "rootRotation": { "$ref": "#/$defs/quaternion" },
    "headPosition": { "anyOf": [{ "$ref": "#/$defs/vector3" }, { "type": "null" }] },
    "headRotation": { "anyOf": [{ "$ref": "#/$defs/quaternion" }, { "type": "null" }] },
    "leftHandPosition": { "anyOf": [{ "$ref": "#/$defs/vector3" }, { "type": "null" }] },
    "leftHandRotation": { "anyOf": [{ "$ref": "#/$defs/quaternion" }, { "type": "null" }] },
    "rightHandPosition": { "anyOf": [{ "$ref": "#/$defs/vector3" }, { "type": "null" }] },
    "rightHandRotation": { "anyOf": [{ "$ref": "#/$defs/quaternion" }, { "type": "null" }] },
    "health": { "type": ["number", "null"] },
    "error": { "type": ["string", "null"] },
    "warnings": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "$defs": {
    "vector3": {
      "type": "object",
      "additionalProperties": false,
      "required": ["x", "y", "z"],
      "properties": {
        "x": { "type": "number" },
        "y": { "type": "number" },
        "z": { "type": "number" }
      }
    },
    "quaternion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["x", "y", "z", "w"],
      "properties": {
        "x": { "type": "number" },
        "y": { "type": "number" },
        "z": { "type": "number" },
        "w": { "type": "number" }
      }
    }
  }
}
